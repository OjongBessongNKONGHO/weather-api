# Database
DATABASE_URL=postgresql+psycopg://weather_user:weather_password@localhost:5432/weather_api

# API Security
API_KEY_SECRET=your-secret-key-here

# App settings
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# OpenWeatherMap
OPENWEATHER_API_KEY=your-openweathermap-api-key-here